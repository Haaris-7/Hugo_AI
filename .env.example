HUGO_ENV=development
HUGO_DATABASE_URL=sqlite:///./hugo.db
HUGO_API_TOKEN=change-me
HUGO_AGENT_TOKEN=change-agent-token
HUGO_INLINE_JOBS=true
HUGO_AUTOMATION_POLL_SECONDS=30

HUGO_HERMES_BASE_URL=http://127.0.0.1:8642/v1
HUGO_HERMES_API_KEY=
HUGO_HERMES_MODEL=nvidia/nemotron-3-ultra-550b-a55b
HUGO_REQUIRE_NEMOCLAW=true
HUGO_HERMES_CRON_ACTIVE=false

HUGO_STRIPE_SECRET_KEY=
HUGO_STRIPE_WEBHOOK_SECRET=
HUGO_STRIPE_SUCCESS_URL=http://localhost:3000/campaigns/{campaign_id}?funding=success
HUGO_STRIPE_CANCEL_URL=http://localhost:3000/campaigns/{campaign_id}?funding=cancelled
HUGO_STRIPE_CONNECT_REFRESH_URL=http://localhost:3000/system
HUGO_STRIPE_CONNECT_RETURN_URL=http://localhost:3000/system

HUGO_GMAIL_SENDER=
HUGO_GMAIL_ACCESS_TOKEN=
HUGO_GMAIL_CLIENT_ID=
HUGO_GMAIL_CLIENT_SECRET=
HUGO_GMAIL_REFRESH_TOKEN=
HUGO_GMAIL_LOOKBACK_DAYS=30
HUGO_EMAIL_TRANSPORT=gmail_api
HUGO_BROWSER_EMAIL_PROVIDER=gmail
HUGO_BROWSER_EMAIL_SENDER=

HUGO_NVIDIA_API_KEY=
HUGO_NVIDIA_VISION_BASE_URL=https://integrate.api.nvidia.com/v1
HUGO_NVIDIA_VISION_MODEL=nvidia/nemotron-nano-12b-v2-vl

# Demo mode — seed sample data, skip real API calls.
HUGO_DEMO_MODE=false
HUGO_DEMO_REAL_PROVIDERS=
HUGO_NVIDIA_BUILD_API_KEY=
HUGO_NVIDIA_BUILD_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1

# Creator discovery — "hermes_agents" or "influencers_club".
HUGO_DISCOVERY_MODE=hermes_agents
HUGO_INFLUENCERS_CLUB_API_KEY=

# Optional integrations.
HUGO_YOUTUBE_API_KEY=
HUGO_TELEGRAM_BOT_TOKEN=
HUGO_TELEGRAM_APPROVAL_MODE=full_autonomy

# Consumed by the hugo-ops Hermes plugin inside NemoClaw (see hermes-plugin/hugo-ops/plugin.yaml).
# Not read by the Docker Compose stack itself.
HUGO_INTERNAL_API_URL=http://host.docker.internal:8000
